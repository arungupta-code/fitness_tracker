# React dev server (browser: http://localhost:<PORT>)
PORT=3000

# MUST match your Express server port (see terminal: [server] Listening on http://localhost:XXXX)
# Your server uses 2345 — keep this in sync or signup will 502 (proxy aimed at wrong port).
REACT_APP_API_PORT=2345

# Optional full URL override (wins over REACT_APP_API_PORT):
# REACT_APP_PROXY_TARGET=http://127.0.0.1:2345

# Do not set REACT_APP_API_URL to localhost in dev — use relative /api/ + proxy above.
